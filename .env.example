# ── Sëtu — Variables d'environnement ──────────────────────────
# Copie ce fichier en .env et remplis tes vraies valeurs

BUSINESS_NAME=Sëtu

# WhatsApp Business API (Meta)
WHATSAPP_TOKEN=ton_token_meta_ici
WHATSAPP_PHONE_ID=ton_phone_id_ici
VERIFY_TOKEN=dakar2025

# Tenant ID (ton ID dans Supabase)
TENANT_ID=ton_tenant_id_ici

# Groq (LLM principal + Whisper)
GROQ_API_KEY=ton_groq_api_key_ici

# Google Gemini (pour les réponses en Wolof)
GEMINI_API_KEY=ton_gemini_api_key_ici

# Supabase (base de données)
SUPABASE_URL=ton_supabase_url_ici
SUPABASE_SERVICE_KEY=ton_supabase_service_key_ici
